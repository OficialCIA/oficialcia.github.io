<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfólio - Olimp.io</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #f5f7fa;
        }
        header {
            background: #1a237e;
            color: #fff;
            padding: 20px 0;
            text-align: center;
        }
        main {
            max-width: 950px;
            margin: 40px auto;
            padding: 16px;
        }
        h1 {
            margin-top: 0;
        }
        .projects-container {
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
            justify-content: center;
        }
        .project-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 2px 12px rgba(60,60,180,0.05);
            width: 310px;
            overflow: hidden;
            transition: box-shadow .2s;
        }
        .project-card:hover {
            box-shadow: 0 6px 20px rgba(60,60,180,0.16);
        }
        .project-img {
            width: 100%;
            height: 160px;
            object-fit: cover;
            background: #e3e3f7;
        }
        .project-content {
            padding: 18px 16px 12px 16px;
        }
        .project-title {
            font-size: 1.2rem;
            font-weight: bold;
            color: #3d387a;
            margin: 0 0 7px 0;
        }
        .project-desc {
            color: #555;
            margin-bottom: 14px;
        }
        .project-links a {
            display: inline-block;
            margin-right: 11px;
            text-decoration: none;
            color: #283593;
            font-weight: 500;
        }
        .project-links a:hover {
            text-decoration: underline;
        }
        @media (max-width: 850px) {
            .projects-container {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
</head>
<body>
    <header>
        <h1>Meu Portfólio</h1>
        <nav>
            <a href="index.html" style="color: #FFD600; margin-right:14px">Home</a>
            <a href="portifolio.html" style="color: #FFD600; font-weight: bold;">Portfólio</a>
            <!-- Adicione outros links do menu aqui -->
        </nav>
    </header>
    <main>
        <section>
            <h2>Projetos em Destaque</h2>
            <div class="projects-container">
                <!-- Exemplo de projeto -->
                <div class="project-card">
                    <img 
                        src="https://source.unsplash.com/600x400/?code,project" 
                        alt="Imagem do Projeto" 
                        class="project-img"
                    >
                    <div class="project-content">
                        <div class="project-title">Projeto 1 Exemplo</div>
                        <div class="project-desc">
                            Descrição curta do projeto. Explique objetivo, tecnologias usadas ou resultado atingido.
                        </div>
                        <div class="project-links">
                            <a href="https://github.com/seurepo/projeto1" target="_blank">GitHub</a>
                            <a href="https://seudemo.com" target="_blank">Demo</a>
                        </div>
                    </div>
                </div>
                <!-- Outro projeto -->
                <div class="project-card">
                    <img 
                        src="https://source.unsplash.com/601x400/?app,website" 
                        alt="Imagem do Projeto" 
                        class="project-img"
                    >
                    <div class="project-content">
                        <div class="project-title">Projeto 2 Legal</div>
                        <div class="project-desc">
                            Mais um exemplo de projeto interessante para o seu portfólio.
                        </div>
                        <div class="project-links">
                            <a href="https://github.com/seurepo/projeto2" target="_blank">GitHub</a>
                        </div>
                    </div>
                </div>
                <!-- Adicione mais projetos copiando o bloco acima -->
            </div>
        </section>
    </main>
</body>
</html>
